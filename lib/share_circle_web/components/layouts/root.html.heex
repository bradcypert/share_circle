<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="ShareCircle">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="bg-base-100 text-base-content min-h-screen">
    <%!-- Minimal nav for auth/settings pages. Hidden by app_shell via fixed overlay. --%>
    <nav class="border-b border-base-300 px-6 py-2.5 flex items-center justify-between">
      <.link href={~p"/"} class="text-sm font-semibold text-base-content">ShareCircle</.link>
      <div class="flex items-center gap-4">
        <%= if @current_scope do %>
          <span class="text-xs text-base-content/50">{@current_scope.user.email}</span>
          <.link href={~p"/users/settings"} class="text-xs text-base-content/60 hover:text-base-content transition-colors">
            Settings
          </.link>
          <.link href={~p"/users/log-out"} method="delete" class="text-xs text-base-content/60 hover:text-base-content transition-colors">
            Log out
          </.link>
        <% else %>
          <.link href={~p"/users/log-in"} class="text-xs text-base-content/60 hover:text-base-content transition-colors">
            Log in
          </.link>
          <.link href={~p"/users/register"} class="text-xs text-base-content/60 hover:text-base-content transition-colors">
            Register
          </.link>
        <% end %>
      </div>
    </nav>
    {@inner_content}
  </body>
</html>
