# Copy this file to .env and fill in the values before running docker compose.
# Generate SECRET_KEY_BASE with: openssl rand -base64 48

VERSION=latest
PHX_HOST=your-domain.com
SECRET_KEY_BASE=
DB_PASSWORD=

# Mail — set MAIL_ADAPTER to postmark or ses to use those instead of SMTP
MAIL_ADAPTER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
